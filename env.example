# OVH VPS Stock Checker - biến môi trường mẫu
# Copy thành .env và điền giá trị thật (không commit .env)

# Bắt buộc để gửi Telegram khi có hàng
TELEGRAM_TOKEN=your_bot_token_from_@BotFather

TELEGRAM_CHAT_ID=your_chat_id


# Chế độ chạy: once (một lần, cho GitHub Actions) | continuous (lặp mãi, cho local)
MODE=continuous

# Khoảng giữa mỗi lần kiểm tra (giây), tối thiểu 30
CHECK_INTERVAL=60

# Chỉ thông báo khi có hàng (mặc định: false = báo cả hết hàng và có hàng)
# Khi bot chạy ổn định, set thành true để tránh spam
NOTIFY_ONLY_IN_STOCK=false
